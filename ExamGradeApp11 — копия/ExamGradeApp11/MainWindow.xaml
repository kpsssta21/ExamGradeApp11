<Window x:Class="ExamGradeApp11.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Система оценивания демонстрационного экзамена" 
        Height="550" Width="500"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Демонстрационный экзамен" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" HorizontalAlignment="Center"/>

        <GroupBox Grid.Row="1" Header="Уровень экзамена" Margin="0,5">
            <StackPanel Margin="10">
                <RadioButton x:Name="rbBU" Content="Базовый " GroupName="Level" Margin="5" IsChecked="True"/>
                <RadioButton x:Name="rbPU" Content="Профильный " GroupName="Level" Margin="5"/>
                <RadioButton x:Name="rbPUPlus" Content="Профильный+ " GroupName="Level" Margin="5"/>
            </StackPanel>
        </GroupBox>

        <GroupBox Grid.Row="2" Header="Баллы по модулям" Margin="0,5">
            <StackPanel Margin="10">
                <Label Content="Модуль 1 (макс. 10 баллов):" Margin="0,2"/>
                <TextBox x:Name="txtModule1" Text="0" Width="150" HorizontalAlignment="Left"/>

                <Label Content="Модуль 2 (макс. 15 баллов):" Margin="0,2"/>
                <TextBox x:Name="txtModule2" Text="0" Width="150" HorizontalAlignment="Left"/>

                <Label Content="Модуль 3 (макс. 25 баллов):" Margin="0,2"/>
                <TextBox x:Name="txtModule3" Text="0" Width="150" HorizontalAlignment="Left"/>

                <Label Content="Модуль 4 (макс. 25 баллов):" Margin="0,2"/>
                <TextBox x:Name="txtModule4" Text="0" Width="150" HorizontalAlignment="Left" IsEnabled="False"/>

                <Label Content="Модуль 5 (макс. 25 баллов):" Margin="0,2"/>
                <TextBox x:Name="txtModule5" Text="0" Width="150" HorizontalAlignment="Left" IsEnabled="False"/>
            </StackPanel>
        </GroupBox>

        <Button x:Name="btnCalculate" Grid.Row="3" Content="Рассчитать оценку" Click="btnCalculate_Click" 
                Margin="0,15" Height="35" Width="200" HorizontalAlignment="Center"/>

        <GroupBox Grid.Row="4" Header="Результат" Margin="0,5">
            <StackPanel Margin="10">
                <TextBlock x:Name="tbTotalScore" Text="Сумма баллов: 0" FontSize="14" Margin="0,3"/>
                <TextBlock x:Name="tbGrade" Text="Оценка: -" FontSize="14" FontWeight="Bold" Margin="0,3"/>
            </StackPanel>
        </GroupBox>

       
    </Grid>
</Window>